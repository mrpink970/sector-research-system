name: Collect Options Data

on:
  schedule:
    - cron: '45 23 * * 1-5'   # 23:45 UTC weekdays (after market close)
  workflow_dispatch:

permissions:
  contents: write

jobs:
  collect-options:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repo
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'

      - name: Install packages
        run: |
          pip install yfinance pandas

      - name: Run options data collection
        run: |
          python collect_options_data.py

      - name: Commit options data
        run: |
          git config --global user.name "github-actions"
          git config --global user.email "actions@github.com"
          git add options_data.csv
          git diff --cached --quiet && echo "No changes" || git commit -m "Daily options data update"
          git push
